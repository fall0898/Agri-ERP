APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:4200
SANCTUM_STATEFUL_DOMAINS=localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en_en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@agri-erp.com"
MAIL_FROM_NAME="Agri-ERP"
RESEND_API_KEY=

# Cloudflare R2 — stockage médias (compatible S3)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=agri-erp-medias
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://<your-custom-domain-or-r2-public-url>

# Sentry — monitoring erreurs production
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"

# Paiements Wave (https://www.wave.com/fr/business/api/)
WAVE_API_KEY=
WAVE_SECRET_KEY=
WAVE_API_URL=https://api.wave.com/v1

# Paiements Orange Money Business
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_SECRET_KEY=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1

# WhatsApp Agent IA
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
OPENAI_API_KEY=
TWILIO_VALIDATE_SIGNATURE=false
